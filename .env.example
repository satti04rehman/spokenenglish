# Server Configuration
PORT=4000
NODE_ENV=production

# MongoDB Atlas Connection (Replace with your own URI)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=spoken-english

# JWT Secrets (Generate strong random strings in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRES_IN=1h

# Client URL (Update to your deployed domain)
CLIENT_URL=https://yourdomain.com

# Security Settings
MAX_FAILED_LOGINS=5
LOCK_DURATION_MS=600000

# Database Mode (Set to false for MongoDB production)
USE_MEMORY_DB=false

# Optional: Redis Cache (if you want to enable it)
# REDIS_URL=redis://localhost:6379
